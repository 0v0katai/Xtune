#define XTUNE_VERSION "@XTUNE_GIT_VERSION@"
#define XTUNE_HASH 0x@XTUNE_GIT_HASH@

#if defined CP400
# define ADDIN_NAME "CPtune4"
# define HARDWARE_TARGET HWCALC_FXCP400
# define XTUNE_STR ADDIN_NAME " " XTUNE_VERSION " @@XTUNE_GIT_HASH@"
#elif defined MONO_SH3
# define ADDIN_NAME "Ftune4 SH3"
# define HARDWARE_TARGET HWCALC_FX9860G_SH3
#elif defined MONO_SH4A
# define ADDIN_NAME "Ftune4 SH4A"
# define HARDWARE_TARGET HWCALC_FX9860G_SH4
#elif defined CG20
# define ADDIN_NAME "Ptune4 Prizm"
# define HARDWARE_TARGET HWCALC_PRIZM
# define PLATFORM "fx-CG10/20"
#elif defined CG50
# if defined TARGET_FXCG50_FASTLOAD
#  define ADDIN_NAME "Ptune4 Fastload"
# else
#  define ADDIN_NAME "Ptune4 CG50"
# endif
# define HARDWARE_TARGET HWCALC_FXCG50
# define PLATFORM "fx-CG50(AU)/Graph 90+E"
#elif defined CG100
# define ADDIN_NAME "Ptune4 MPM"
# define HARDWARE_TARGET HWCALC_FXCG100
