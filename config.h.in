#pragma once

#include <gint/keycodes.h>
#include <gint/hardware.h>

#cmakedefine01 FXSH4
#cmakedefine01 CG20
#cmakedefine01 CG50
#cmakedefine01 CG100
#cmakedefine01 CP400

#cmakedefine DHRYSTONE @DHRYSTONE@
#cmakedefine01 USB
#cmakedefine01 HELP
#cmakedefine WHETSTONE @WHETSTONE@
#cmakedefine01 AZUR
#cmakedefine01 GDB

#if GDB
# undef USB
#endif

#define XTUNE_VERSION "@XTUNE_GIT_VERSION@"
#define XTUNE_HASH 0x@XTUNE_GIT_HASH@

#if FXSH4
# define __(fxsh4, cg20, cg50, cg100, cp400) fxsh4
#elif CG20
# define __(fxsh4, cg20, cg50, cg100, cp400) cg20
#elif CG50
# define __(fxsh4, cg20, cg50, cg100, cp400) cg50
#elif CG100
# define __(fxsh4, cg20, cg50, cg100, cp400) cg100
#elif CP400
# define __(fxsh4, cg20, cg50, cg100, cp400) cp400
#else
# error "No target defined!"
#endif

#define MHZ(x) ((x) * 1000000)
#define XTUNE_STR ADDIN_NAME " " XTUNE_VERSION " @@XTUNE_GIT_HASH@"

#if defined TARGET_FXCG50_FASTLOAD
# define ADDIN_NAME "Ptune4 Fastload"
#else
# define ADDIN_NAME __( \
    "Ftune4 SH4A", "Ptune4 Prizm", "Ptune4 CG50", \
    "Ptune4 MPM", "CPtune4" \
)
#endif
#define HARDWARE_TARGET __( \
    HWCALC_FX9860G_SH4, HWCALC_PRIZM, HWCALC_FXCG50, \
    HWCALC_FXCG100, HWCALC_FXCP400 \
)
#define PLATFORM __( \
    "fx-9860G SH4A", "fx-CG10/20", "fx-CG50(AU)/Graph 90+E", \
    "fx-CG100/1AU/Graph Math+", "fx-CP400(+E)/CG500" \
)

/* Keybinds */
#define KEY_EXPRESS_SELXM __(KEY_SQUARE, KEY_SQUARE, KEY_SQUARE, KEY_XOT, KEY_COMMA)
#define KEY_EXPRESS_SS __(KEY_POWER, KEY_POWER, KEY_POWER, KEY_LOG, KEY_NEG)
#define KEY_EXPRESS_SETTINGS __(KEY_MENU, KEY_MENU, KEY_MENU, KEY_SETTINGS, KEY_EQUALS)
#define KEY_EXPRESS_BENCHMARK __(KEY_F6, KEY_F6, KEY_F6, KEY_PAGEUP, KEY_DEL)
#define KEY_EXPRESS_BSC __(KEY_VARS, KEY_VARS, KEY_VARS, KEY_VARS, KEY_LEFTP)
#define KEY_EXPRESS_MEMDATA __(KEY_OPTN, KEY_OPTN, KEY_OPTN, KEY_TOOLS, KEY_RIGHTP)
#define KEY_BSC_BCRWCR __(KEY_F6, KEY_F6, KEY_F6, KEY_NEXTTAB, KEY_DEL)
#define KEY_MEMDATA_RESET __(KEY_F1, KEY_F1, KEY_F1, KEY_ON, KEY_KBD)
#define KEY_MEMDATA_MARGIN __(KEY_F3, KEY_F3, KEY_F3, KEY_PREVTAB, KEY_Y)
#define KEY_MEMDATA_ROMTEST __(KEY_F5, KEY_F5, KEY_F5, KEY_NEXTTAB, KEY_CARET)
#define KEY_MEMDATA_RAMTEST __(KEY_F6, KEY_F6, KEY_F6, KEY_PAGEUP, KEY_DIV)
#define KEY_SETTINGS_RESET __(KEY_F1, KEY_F1, KEY_F1, KEY_ON, KEY_KBD)
#define KEY_SETTINGS_ABOUT __(KEY_F6, KEY_F6, KEY_F6, KEY_PAGEUP, KEY_DEL)
#define KEY_ENABLE_USB __(KEY_7, KEY_7, KEY_7, KEY_EXP, KEY_7)
#define KEY_OPEN_HELP __(KEY_4, KEY_4, KEY_4, KEY_CATALOG, KEY_8)
#define KEY_SAVE_CONFIG __(KEY_F1, KEY_F1, KEY_F1, KEY_ON, KEY_KBD)
#define KEY_DEFAULT_PRESET __(KEY_F1, KEY_F1, KEY_F1, KEY_ON, KEY_KBD)

/* Settings defaults */
#define PLL_CLK_MAX_DEF MHZ(800)
#define IFC_CLK_MAX_DEF MHZ(275)
#define SFC_CLK_MAX_DEF MHZ(180)
#define BFC_CLK_MAX_DEF MHZ(134)
#define PFC_CLK_MAX_DEF __(MHZ(24), MHZ(24), MHZ(50), MHZ(50), MHZ(50))
#define UNLOCKED_MODE_DEF false
#define AUTO_REDUCE_WAIT_DEF true
#define AUTO_UP_PFC_DEF true
#define STARTUP_MEMORY_TEST_DEF true
#define F1_YES_NO_DEF true
#define TEST_ROR_10_12_DEF true

#define PLL_MAX MHZ(1000)
#define CPU_MAX MHZ(350)
#define SHW_MAX MHZ(200)
#define BUS_MAX MHZ(200)
#define IO_MAX MHZ(60)

#define FLL_RED_ZONE MHZ(17)
#define PLL_RED_ZONE MHZ(750)
#define IFC_RED_ZONE MHZ(250)
#define SFC_RED_ZONE MHZ(150)
#define BFC_RED_ZONE MHZ(120)
#define PFC_RED_ZONE __(MHZ(25), MHZ(25), MHZ(48), MHZ(48), MHZ(48))

